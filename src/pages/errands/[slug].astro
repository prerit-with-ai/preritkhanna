---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const errands = await getCollection('errands');
  return errands.map((errand) => ({
    params: { slug: errand.id },
    props: { errand },
  }));
}

interface Props {
  errand: CollectionEntry<'errands'>;
}

const { errand } = Astro.props;
const { Content } = await render(errand);
const { title, tagline, status, started, threads, looking_for, links, updates } = errand.data;

const startedLabel = started.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const sortedUpdates = updates
  ? [...updates].sort((a, b) => b.date.valueOf() - a.date.valueOf())
  : [];
---

<Base title={`${title} — Fool's Errand`} description={tagline}>
  <p class="small"><a href="/errands/">← all errands</a></p>

  <header>
    {threads && threads.length > 0 && (
      <p class="small muted threads">
        Threads: {threads.map((t, i) => (
          <>
            {i > 0 && <span> · </span>}
            <a href={`/threads/${t}/`}>{t}</a>
          </>
        ))}
      </p>
    )}
    <h1>{title}</h1>
    <p class="lede">{tagline}</p>
    <p class="meta small muted">
      <span class={`status status-${status}`}>{status}</span>
      <span> · started {startedLabel}</span>
    </p>
  </header>

  <hr />

  <article>
    <Content />
  </article>

  {looking_for && (
    <aside class="looking-for">
      <p class="small sans muted">Looking for</p>
      <p>{looking_for}</p>
    </aside>
  )}

  {
    links && links.length > 0 && (
      <section>
        <h2>Links</h2>
        <ul>
          {links.map((link) => (
            <li>
              <a href={link.url}>{link.label}</a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    sortedUpdates.length > 0 && (
      <section>
        <h2>Updates</h2>
        <ul class="updates">
          {sortedUpdates.map((u) => (
            <li>
              <span class="small muted">
                {u.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
              <p>{u.note}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>

<style>
  .threads {
    margin: 0 0 var(--space-3);
  }
  .lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--type-xl);
    color: var(--muted);
    margin: var(--space-2) 0 var(--space-3);
  }
  .meta {
    margin: 0;
  }
  .looking-for {
    border-left: 2px solid var(--accent);
    padding: var(--space-3) 0 var(--space-3) var(--space-4);
    margin: var(--space-6) 0;
  }
  .looking-for p {
    margin: var(--space-1) 0 0;
  }
  .updates {
    list-style: none;
    padding: 0;
  }
  .updates li {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--rule);
  }
  .updates li:last-child {
    border-bottom: 0;
  }
  .updates p {
    margin: var(--space-1) 0 0;
  }
</style>
