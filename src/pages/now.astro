---
import Base from '../layouts/Base.astro';
import { Content, frontmatter } from '../content/now.md';

const lastUpdated = new Date(frontmatter.last_updated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title="Now — Prerit Khanna" description="What I'm building, reading, thinking about, where I am.">
  <p class="small"><a href="/">← home</a></p>

  <header>
    <h1>Now</h1>
    <p class="small muted">Last updated {lastUpdated}</p>
  </header>

  <hr />

  <article>
    <Content />
  </article>
</Base>
