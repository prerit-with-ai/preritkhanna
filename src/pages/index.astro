---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ErrandCard from '../components/ErrandCard.astro';

const errands = (await getCollection('errands')).sort(
  (a, b) => b.data.started.valueOf() - a.data.started.valueOf()
);
---

<Base title="Prerit Khanna — Fool's Errand">
  <header>
    <h1>Fool's Errand</h1>
    <p class="muted">
      A public log of attempts by Prerit Khanna. Some serious, some absurd, some
      abandoned. Each one is an errand.
    </p>
  </header>

  <hr />

  <section>
    {errands.map((errand) => <ErrandCard errand={errand} />)}
  </section>
</Base>
