---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const essays = (await getCollection('essays'))
  .filter((e) => e.data.status === 'published' || e.data.status === 'draft')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Essays — Prerit Khanna">
  <p class="small"><a href="/">← home</a></p>

  <header>
    <h1>Essays</h1>
    <p class="lede">Long-form thinking. Often retrospective on errands. Drafts allowed and labeled.</p>
  </header>

  <hr />

  <section>
    <ul class="essay-list">
      {essays.map((essay) => (
        <li>
          <a href={`/essays/${essay.id}/`}>
            <h2>
              {essay.data.title}
              {essay.data.status === 'draft' && <span class="status status-draft"> [draft]</span>}
            </h2>
            {essay.data.dek && <p class="dek">{essay.data.dek}</p>}
            <p class="meta small muted">
              {essay.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .lede {
    font-family: var(--serif);
    font-size: var(--type-lg);
    color: var(--muted);
    margin: var(--space-2) 0 0;
  }
  .essay-list {
    list-style: none;
    padding: 0;
  }
  .essay-list > li {
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--rule);
  }
  .essay-list > li:last-child {
    border-bottom: 0;
  }
  .essay-list a {
    text-decoration: none;
    display: block;
  }
  .essay-list h2 {
    margin: 0 0 var(--space-2);
    font-size: var(--type-xl);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }
  .essay-list a:hover h2 {
    text-decoration-color: var(--accent);
  }
  .dek {
    font-style: italic;
    color: var(--muted);
    margin: 0 0 var(--space-2);
  }
  .meta {
    margin: 0;
  }
</style>
