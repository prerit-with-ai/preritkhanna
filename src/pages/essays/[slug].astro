---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

interface Props {
  essay: CollectionEntry<'essays'>;
}

const { essay } = Astro.props;
const { Content } = await render(essay);
const { title, dek, date, last_updated, status, threads } = essay.data;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${title} — Prerit Khanna`} description={dek}>
  <p class="small"><a href="/essays/">← all essays</a></p>

  <header>
    {threads && threads.length > 0 && (
      <p class="small muted threads">
        Threads: {threads.map((t, i) => (
          <>
            {i > 0 && <span> · </span>}
            <a href={`/threads/${t}/`}>{t}</a>
          </>
        ))}
      </p>
    )}
    <h1>
      {title}
      {status === 'draft' && <span class="status status-draft"> [draft]</span>}
    </h1>
    {dek && <p class="lede">{dek}</p>}
    <p class="meta small muted">
      <span>{fmt(date)}</span>
      {last_updated && <span> · last updated {fmt(last_updated)}</span>}
    </p>
  </header>

  <hr />

  <article>
    <Content />
  </article>
</Base>

<style>
  .threads { margin: 0 0 var(--space-3); }
  .lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--type-xl);
    color: var(--muted);
    margin: var(--space-2) 0 var(--space-3);
  }
  .meta { margin: 0; }
</style>
