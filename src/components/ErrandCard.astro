---
import type { CollectionEntry } from 'astro:content';

interface Props {
  errand: CollectionEntry<'errands'>;
}

const { errand } = Astro.props;
const { title, tagline, status, started } = errand.data;
const startedLabel = started.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
});
---

<article class="errand-card">
  <a href={`/errands/${errand.id}/`}>
    <h2>{title}</h2>
    <p class="tagline">{tagline}</p>
    <p class="meta small muted">
      <span class={`status status-${status}`}>{status}</span>
      <span> · </span>
      <span>{startedLabel}</span>
    </p>
  </a>
</article>

<style>
  .errand-card {
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--rule);
  }
  .errand-card:last-child {
    border-bottom: 0;
  }
  .errand-card a {
    text-decoration: none;
    display: block;
  }
  .errand-card a:hover h2 {
    text-decoration-color: var(--accent);
  }
  .errand-card h2 {
    margin: 0 0 var(--space-2);
    font-size: var(--type-xl);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-color 0.15s ease;
  }
  .tagline {
    margin: 0 0 var(--space-3);
    color: var(--fg);
  }
  .meta {
    margin: 0;
  }
</style>
